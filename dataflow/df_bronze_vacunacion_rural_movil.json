{
	"name": "df_bronze_vacunacion_rural_movil",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "vacunacion_rural_movil_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_consolidada",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          record_id as string,",
				"          sync_timestamp as string,",
				"          device_id as string,",
				"          patient_id as string,",
				"          patient_ci as string,",
				"          patient_name as string,",
				"          patient_last_name_1 as string,",
				"          patient_last_name_2 as string,",
				"          patient_sex as string,",
				"          patient_birth_date as string,",
				"          patient_department as string,",
				"          patient_municipality as string,",
				"          patient_community as string,",
				"          patient_indigenous as string,",
				"          vaccination_date as string,",
				"          vaccine_code as string,",
				"          vaccine_name as string,",
				"          dose_number as string,",
				"          facility_code as string,",
				"          facility_name as string,",
				"          lot_number as string,",
				"          storage_temp_celsius as string,",
				"          patient_age_days as string,",
				"          administration_route as string,",
				"          gps_latitude as string,",
				"          gps_longitude as string,",
				"          gps_accuracy_meters as string,",
				"          observations as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(id_registro_origen = trim(record_id),",
				"          cod_paciente = trim(patient_id),",
				"          documento_identidad = trim(patient_ci),",
				"          fecha_nacimiento = coalesce(\r",
				"    toDate(patient_birth_date, 'yyyy-MM-dd'),\r",
				"    toDate(patient_birth_date, 'dd/MM/yyyy'),\r",
				"    toDate(patient_birth_date, 'MM-dd-yyyy'),\r",
				"    toDate(patient_birth_date, 'yyyy/MM/dd'),\r",
				"    toDate(patient_birth_date, 'dd-MMM-yyyy'),\r",
				"    toDate(patient_birth_date, 'MMMM dd, yyyy'),\r",
				"    toDate(patient_birth_date, \"dd 'de' MMMM 'de' yyyy\")\r",
				")\r",
				"\r",
				"\r",
				"\r",
				"\r",
				"\r",
				",",
				"          comunidad_o_pueblo_indigena = trim(patient_community),",
				"          es_indigena = toBoolean(patient_indigenous),",
				"          fecha_vacunacion = toDate(vaccination_date),",
				"          cod_vacuna = trim(vaccine_code),",
				"          desc_vacuna = trim(vaccine_name),",
				"          cod_establecimiento = trim(facility_code),",
				"          desc_establecimiento = trim(facility_name),",
				"          temperatura_conservacion = toDecimal(storage_temp_celsius),",
				"          via_aplicacion = trim(administration_route),",
				"          nombres = initCap(trim(patient_name)),",
				"          primer_apellido = initCap(trim(patient_last_name_1)),",
				"          segundo_apellido = initCap(trim(patient_last_name_2)),",
				"          genero = case(     upper(trim(patient_sex)) == 'M', 'Masculino',     upper(trim(patient_sex)) == 'F', 'Femenino',     upper(trim(patient_sex)) == 'MALE', 'Masculino',     upper(trim(patient_sex)) == 'FEMALE', 'Femenino',     'No especificado' ),",
				"          municipio = initCap(trim(patient_municipality)),",
				"          nro_dosis = iif(     isNull(dose_number) || trim(toString(dose_number)) == '',     0,     toInteger(dose_number) ),",
				"          departamento = initCap(trim(patient_department)),",
				"          nro_lote = trim(lot_number),",
				"          edad_dias = iif(     isNull(patient_age_days) || trim(toString(patient_age_days)) == '',     0,     toInteger(patient_age_days) )) ~> derivedColumn1",
				"derivedColumn1 filter(!isNull(documento_identidad)) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_registro_origen as string,",
				"          cod_paciente as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio as string,",
				"          comunidad_o_pueblo_indigena as string,",
				"          es_indigena as boolean,",
				"          fecha_vacunacion as date,",
				"          cod_vacuna as string,",
				"          desc_vacuna as string,",
				"          nro_dosis as integer,",
				"          cod_establecimiento as string,",
				"          desc_establecimiento as string,",
				"          departamento as string,",
				"          nro_lote as string,",
				"          temperatura_conservacion as decimal(5,2),",
				"          edad_dias as integer,",
				"          via_aplicacion as string,",
				"          aplicacion_oportuna as boolean,",
				"          fuente_origen as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          id_registro_origen,",
				"          cod_paciente,",
				"          documento_identidad,",
				"          nombres,",
				"          primer_apellido,",
				"          segundo_apellido,",
				"          genero,",
				"          fecha_nacimiento,",
				"          municipio,",
				"          comunidad_o_pueblo_indigena,",
				"          es_indigena,",
				"          fecha_vacunacion,",
				"          cod_vacuna,",
				"          desc_vacuna,",
				"          nro_dosis,",
				"          cod_establecimiento,",
				"          desc_establecimiento,",
				"          departamento,",
				"          nro_lote,",
				"          temperatura_conservacion,",
				"          edad_dias,",
				"          via_aplicacion",
				"     )) ~> sink1"
			]
		}
	}
}