{
	"name": "df_bronze_vacunacion_la_paz",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "vacunacion_la_paz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_consolidada",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_registro as string,",
				"          cod_paciente as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fec_nacimiento as string,",
				"          municipio as string,",
				"          pueblo_indigena as string,",
				"          fec_vacunacion as string,",
				"          cod_vacuna as string,",
				"          desc_vacuna as string,",
				"          nro_dosis as string,",
				"          cod_establecimiento as string,",
				"          desc_establecimiento as string,",
				"          depto as string,",
				"          nro_lote as string,",
				"          temp_conservacion as string,",
				"          edad_dias as string,",
				"          via_aplicacion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive(id_registro = trim(id_registro),",
				"          cod_paciente = trim(cod_paciente),",
				"          documento_identidad = trim(documento_identidad),",
				"          fec_nacimiento = coalesce(\r",
				"    toDate(fec_nacimiento, 'yyyy-MM-dd'),\r",
				"    toDate(fec_nacimiento, 'dd/MM/yyyy'),\r",
				"    toDate(fec_nacimiento, 'MM-dd-yyyy'),\r",
				"    toDate(fec_nacimiento, 'yyyy/MM/dd'),\r",
				"    toDate(fec_nacimiento, 'dd-MMM-yyyy'),\r",
				"    toDate(fec_nacimiento, 'MMMM dd, yyyy'),\r",
				"    toDate(fec_nacimiento, \"dd 'de' MMMM 'de' yyyy\")\r",
				")\r",
				"\r",
				"\r",
				"\r",
				"\r",
				"\r",
				",",
				"          fec_vacunacion = coalesce(\r",
				"    toDate(fec_vacunacion, 'yyyy-MM-dd'),\r",
				"    toDate(fec_vacunacion, 'dd/MM/yyyy'),\r",
				"    toDate(fec_vacunacion, 'MM-dd-yyyy'),\r",
				"    toDate(fec_vacunacion, 'yyyy/MM/dd'),\r",
				"    toDate(fec_vacunacion, 'dd-MMM-yyyy'),\r",
				"    toDate(fec_vacunacion, 'MMMM dd, yyyy'),\r",
				"    toDate(fec_vacunacion, \"dd 'de' MMMM 'de' yyyy\")\r",
				")\r",
				"\r",
				"\r",
				"\r",
				"\r",
				"\r",
				",",
				"          cod_vacuna = trim(cod_vacuna),",
				"          desc_vacuna = trim(desc_vacuna),",
				"          cod_establecimiento = trim(cod_establecimiento),",
				"          desc_establecimiento = trim(desc_establecimiento),",
				"          nro_lote = trim(nro_lote),",
				"          temp_conservacion = toDecimal(temp_conservacion),",
				"          via_aplicacion = trim(via_aplicacion),",
				"          pueblo_indigena = trim(pueblo_indigena),",
				"          nro_dosis = toInteger(nro_dosis),",
				"          genero = case(\r",
				"    upper(trim(genero)) == 'M', 'Masculino',\r",
				"    upper(trim(genero)) == 'F', 'Femenino',\r",
				"    upper(trim(genero)) == 'MASCULINO', 'Masculino',\r",
				"    upper(trim(genero)) == 'FEMENINO', 'Femenino',\r",
				"    'No especificado'\r",
				")) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          id_registro,",
				"          cod_paciente,",
				"          documento_identidad,",
				"          nombres,",
				"          primer_apellido,",
				"          segundo_apellido,",
				"          genero,",
				"          fec_nacimiento,",
				"          municipio,",
				"          pueblo_indigena,",
				"          fec_vacunacion,",
				"          cod_vacuna,",
				"          desc_vacuna,",
				"          nro_dosis,",
				"          cod_establecimiento,",
				"          desc_establecimiento,",
				"          depto,",
				"          nro_lote,",
				"          temp_conservacion,",
				"          edad_dias,",
				"          via_aplicacion",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_registro_origen as string,",
				"          cod_paciente as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio as string,",
				"          comunidad_o_pueblo_indigena as string,",
				"          es_indigena as boolean,",
				"          fecha_vacunacion as date,",
				"          cod_vacuna as string,",
				"          desc_vacuna as string,",
				"          nro_dosis as integer,",
				"          cod_establecimiento as string,",
				"          desc_establecimiento as string,",
				"          departamento as string,",
				"          nro_lote as string,",
				"          temperatura_conservacion as decimal(5,2),",
				"          edad_dias as integer,",
				"          via_aplicacion as string,",
				"          aplicacion_oportuna as boolean,",
				"          fuente_origen as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}