{
	"name": "df_bronze_vacunacion_santa_cruz",
	"properties": {
		"folder": {
			"name": "bronze"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "vacunacion_santa_cruz_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_vacunacion_consolidada",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          registro_id as string,",
				"          paciente_id as string,",
				"          ci_paciente as string,",
				"          nombre_paciente as string,",
				"          apellido_paterno as string,",
				"          apellido_materno as string,",
				"          sexo as string,",
				"          fecha_nacimiento as string,",
				"          municipio_residencia as string,",
				"          comunidad_indigena as string,",
				"          fecha_vacunacion as string,",
				"          vacuna_id as string,",
				"          vacuna_nombre as string,",
				"          numero_dosis as string,",
				"          establecimiento_id as string,",
				"          nombre_establecimiento as string,",
				"          departamento as string,",
				"          lote_vacuna as string,",
				"          temperatura_conservacion as string,",
				"          edad_dias_aplicacion as string,",
				"          aplicacion_oportuna as string,",
				"          via_administracion as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 derive({ id_registro_origen} = trim(registro_id),",
				"          cod_paciente = trim(paciente_id),",
				"          documento_identidad = trim(ci_paciente),",
				"          nombres = initCap(trim(nombre_paciente)),",
				"          primer_apellido = initCap(trim(apellido_paterno)),",
				"          segundo_apellido = initCap(trim(apellido_materno)),",
				"          genero = case(\r",
				"    upper(trim(sexo)) == 'M', 'Masculino',\r",
				"    upper(trim(sexo)) == 'F', 'Femenino',\r",
				"    upper(trim(sexo)) == 'MASCULINO', 'Masculino',\r",
				"    upper(trim(sexo)) == 'FEMENINO', 'Femenino',\r",
				"    'No especificado'\r",
				"),",
				"          fecha_nacimiento = toDate(fecha_nacimiento, 'dd/MM/yyyy'),",
				"          fecha_vacunacion = toDate(fecha_vacunacion, 'dd/MM/yyyy'),",
				"          municipio = initCap(trim(municipio_residencia)),",
				"          comunidad_o_pueblo_indigena = case(     upper(trim(toString(comunidad_indigena))) == 'TRUE', 'Comunidad indígena no especificada',     upper(trim(toString(comunidad_indigena))) == 'FALSE', 'No aplica',     'No especificado' ),",
				"          es_indigena = case(     upper(trim(toString(comunidad_indigena))) == 'TRUE', true(),     upper(trim(toString(comunidad_indigena))) == 'FALSE', false(),     false() ),",
				"          cod_vacuna = trim(vacuna_id),",
				"          desc_vacuna = initCap(trim(vacuna_nombre)),",
				"          cod_establecimiento = trim(establecimiento_id),",
				"          desc_establecimiento = initCap(trim(nombre_establecimiento)),",
				"          nro_dosis = iif(     isNull(numero_dosis) || trim(toString(numero_dosis)) == '',     0,     toInteger(numero_dosis) ),",
				"          nro_lote = trim(lote_vacuna),",
				"          temperatura_conservacion = toDecimal(temperatura_conservacion),",
				"          edad_dias = toInteger(edad_dias_aplicacion)) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_registro_origen as string,",
				"          cod_paciente as string,",
				"          documento_identidad as string,",
				"          nombres as string,",
				"          primer_apellido as string,",
				"          segundo_apellido as string,",
				"          genero as string,",
				"          fecha_nacimiento as date,",
				"          municipio as string,",
				"          comunidad_o_pueblo_indigena as string,",
				"          es_indigena as boolean,",
				"          fecha_vacunacion as date,",
				"          cod_vacuna as string,",
				"          desc_vacuna as string,",
				"          nro_dosis as integer,",
				"          cod_establecimiento as string,",
				"          desc_establecimiento as string,",
				"          departamento as string,",
				"          nro_lote as string,",
				"          temperatura_conservacion as decimal(5,2),",
				"          edad_dias as integer,",
				"          via_aplicacion as string,",
				"          aplicacion_oportuna as boolean,",
				"          fuente_origen as string,",
				"          fecha_carga as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}